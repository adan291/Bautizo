rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'adanx05@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidMenuSelection(data) {
      return data.keys().hasAll(['userId', 'selectedMenu', 'submittedAt']) &&
             data.userId == request.auth.uid &&
             data.selectedMenu in ['adult_standard', 'adult_vegan', 'kids'] &&
             data.submittedAt == request.time &&
             (data.get('observations', '') is string && data.get('observations', '').size() <= 1000) &&
             (data.get('userName', '') is string && data.get('userName', '').size() <= 100) &&
             (data.get('userEmail', '') is string && data.get('userEmail', '').size() <= 100) &&
             (data.get('aiMessage', '') is string && data.get('aiMessage', '').size() <= 2000);
    }

    // --- Collections ---

    match /responses/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidMenuSelection(incoming());
                      
      allow update: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidMenuSelection(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['selectedMenu', 'observations', 'submittedAt', 'userName', 'userEmail', 'aiMessage']);
                      
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Only manageable via Console or separate backend
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
