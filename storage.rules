rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /bautizo-photos/{fileName} {
      // Anyone can read photos
      allow read: if true;
      // Anyone can upload images up to 5MB
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
